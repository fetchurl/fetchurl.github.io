---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'fetchurl',
  description = 'Content-addressable URL caching for CI and package managers.',
} = Astro.props;

const pageTitle = title === 'fetchurl' ? title : `${title} · fetchurl`;
const canonical = new URL(Astro.url.pathname, Astro.site);
const base = import.meta.env.BASE_URL;
const iconUrl = new URL(`${base}icon-512.png`.replace(/\/{2,}/g, '/').replace(':/', '://'), Astro.site);
---

<!doctype html>
<html lang="en" data-theme="fetchurl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0050d0" />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href={`${base}favicon.png`} type="image/png" sizes="32x32" />
    <link rel="icon" href={`${base}icon-192.png`} type="image/png" sizes="192x192" />
    <link rel="apple-touch-icon" href={`${base}apple-touch-icon.png`} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={iconUrl.href} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:image" content={iconUrl.href} />
    <title>{pageTitle}</title>
    <script is:inline>
      (function () {
        try {
          var t = localStorage.getItem('fetchurl-theme');
          if (t === 'fetchurl' || t === 'fetchurl-dark') {
            document.documentElement.setAttribute('data-theme', t);
          } else if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
            document.documentElement.setAttribute('data-theme', 'fetchurl-dark');
          }
        } catch (e) {}
      })();
    </script>
  </head>
  <body class="flex min-h-dvh flex-col bg-base-100 text-base-content antialiased">
    <a href="#main" class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-50 focus:rounded-field focus:bg-primary focus:px-3 focus:py-2 focus:text-primary-content">
      Skip to content
    </a>
    <Header />
    <main id="main" class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
