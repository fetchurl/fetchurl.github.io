---
import BaseLayout from './BaseLayout.astro';
import { getDocNav } from '../lib/docs';

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  title: string;
  description?: string;
  slug: string;
  headings?: Heading[];
}

const { title, description = '', slug, headings = [] } = Astro.props;
const nav = getDocNav();
const base = import.meta.env.BASE_URL;
// Section nav: h2/h3 only (page title is already the h1).
const toc = headings.filter((h) => h.depth === 2 || h.depth === 3);
---

<BaseLayout title={title} description={description}>
  <div class="mx-auto grid max-w-6xl gap-8 px-4 py-10 lg:grid-cols-[14rem_minmax(0,1fr)]">
    <aside class="lg:sticky lg:top-6 lg:self-start">
      <p class="mb-3 text-xs font-semibold uppercase tracking-wide text-base-content/60">Documentation</p>
      <nav class="menu rounded-box border border-base-300 bg-base-100 p-2" aria-label="Docs">
        <ul>
          {
            nav.map((item) => (
              <li>
                <a
                  href={`${base}docs/${item.slug}/`}
                  class:list={[item.slug === slug && 'active bg-primary text-primary-content']}
                  aria-current={item.slug === slug ? 'page' : undefined}
                >
                  {item.title}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>
      {
        toc.length > 1 && (
          <nav class="mt-6" aria-label="On this page">
            <p class="mb-2 text-xs font-semibold uppercase tracking-wide text-base-content/60">On this page</p>
            <ul class="space-y-1.5 border-l border-base-300 text-sm">
              {toc.map((h) => (
                <li>
                  <a
                    href={`#${h.slug}`}
                    class:list={[
                      'block border-l-2 border-transparent py-0.5 text-base-content/75 transition-colors hover:border-primary hover:text-base-content',
                      h.depth === 2 ? 'pl-3' : 'pl-5 text-[0.8125rem]',
                    ]}
                  >
                    {h.text}
                  </a>
                </li>
              ))}
            </ul>
          </nav>
        )
      }
      <p class="mt-4 text-xs text-base-content/60">
        Normative protocol lives in
        <a class="link" href="https://github.com/fetchurl/spec" target="_blank" rel="noopener noreferrer">fetchurl/spec</a>.
      </p>
    </aside>
    <article class="min-w-0">
      <header class="mb-8 border-b border-base-300 pb-6">
        <h1 class="text-3xl font-semibold tracking-tight text-balance sm:text-4xl">{title}</h1>
        {description && <p class="mt-3 max-w-prose text-base-content/80 text-pretty">{description}</p>}
      </header>
      <div class="prose prose-neutral max-w-none dark:prose-invert prose-headings:font-semibold prose-a:text-primary prose-code:rounded-field prose-code:bg-base-200 prose-code:px-1 prose-code:py-0.5 prose-code:before:content-none prose-code:after:content-none">
        <slot />
      </div>
    </article>
  </div>
</BaseLayout>
