---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getDocNav } from '../../lib/docs';

const base = import.meta.env.BASE_URL;
const docs = getDocNav();
---

<BaseLayout title="Docs" description="fetchurl documentation index.">
  <div class="mx-auto max-w-3xl px-4 py-12">
    <h1 class="text-3xl font-semibold tracking-tight sm:text-4xl">Documentation</h1>
    <p class="mt-3 text-base-content/80 text-pretty">
      Guides for the protocol, reference server, SDKs, and environment setup. Normative text is in
      <a class="link link-primary" href="https://github.com/fetchurl/spec" target="_blank" rel="noopener noreferrer">fetchurl/spec</a>.
    </p>
    <ul class="mt-10 space-y-3">
      {
        docs.map((d, i) => (
          <li>
            <a
              href={`${base}docs/${d.slug}/`}
              class="block rounded-box border border-base-300 bg-base-100 p-5 transition-colors hover:border-primary/40 hover:bg-base-200/40"
            >
              <span class="text-xs font-medium text-base-content/50">{String(i + 1).padStart(2, '0')}</span>
              <span class="mt-1 block text-lg font-semibold">{d.title}</span>
              <span class="mt-1 block text-sm text-base-content/75">{d.description}</span>
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</BaseLayout>
