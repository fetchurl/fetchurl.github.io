---
import BaseLayout from '../layouts/BaseLayout.astro';

const base = import.meta.env.BASE_URL;
---

<BaseLayout
  title="Page not found"
  description="This page does not exist on the fetchurl site."
>
  <div class="mx-auto flex max-w-2xl flex-col items-start gap-6 px-4 py-20">
    <p class="text-sm font-medium text-primary">404</p>
    <h1 class="text-3xl font-semibold tracking-tight text-balance sm:text-4xl">
      Page not found
    </h1>
    <p class="max-w-prose text-base-content/80 text-pretty">
      That URL is not part of this site. Try the documentation index, or start from the home page.
    </p>
    <div class="flex flex-wrap gap-3">
      <a class="btn btn-primary rounded-field shadow-none" href={base}>Home</a>
      <a class="btn btn-outline border-base-300 rounded-field shadow-none" href={`${base}docs/`}>
        Documentation
      </a>
    </div>
  </div>
</BaseLayout>
